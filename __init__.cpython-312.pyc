# ============================================================
# ФАЙЛ: tests/test_analyser.py
# ЗАДАЧА: Юнит-тесты для TopStudentsAnalyser (Вариант D).
#         Task 3 & 4, Practice 8.
# ============================================================
#
# Что такое юнит-тест?
# Юнит-тест проверяет одну единицу кода (класс или функцию) изолированно.
# Мы НЕ загружаем CSV — используем маленький ручной набор данных (5 строк).
# Это делает тесты быстрыми, предсказуемыми и независимыми от файлов.
#
# Структура тестового класса:
# - Наследуем от unittest.TestCase — получаем все assert-методы
# - setUp() запускается ПЕРЕД каждым тестом — создаёт чистый набор данных
# - Каждый метод test_*() — это один тест
# ============================================================

# Test results:
# test_analyse_twice (tests.test_analyser.TestTopStudentsAnalyser) ... ok
# test_result_has_required_keys (tests.test_analyser.TestTopStudentsAnalyser) ... ok
# test_result_is_not_empty (tests.test_analyser.TestTopStudentsAnalyser) ... ok
# test_total_students (tests.test_analyser.TestTopStudentsAnalyser) ... ok
#
# ----------------------------------------------------------------------
# Ran 4 tests in 0.001s
#
# OK

import unittest
# Импортируем именно дочерний класс Варианта D
from analytics.analyser import TopStudentsAnalyser


class TestTopStudentsAnalyser(unittest.TestCase):
    """
    Тестовый класс для TopStudentsAnalyser (Вариант D).
    
    unittest.TestCase предоставляет методы-утверждения (assertions):
    assertEqual, assertNotEqual, assertIn, assertTrue, assertGreater и др.
    
    Если утверждение оказывается ложным — тест падает (FAIL),
    и unittest показывает, что именно не совпало.
    """

    def setUp(self):
        """
        setUp() — специальный метод, который unittest вызывает
        АВТОМАТИЧЕСКИ перед каждым отдельным тестом.
        
        Здесь создаётся минимальный датасет из 5 студентов.
        Ключи словарей ДОЛЖНЫ совпадать с ключами реального CSV —
        именно по ним обращается метод analyse() в TopStudentsAnalyser.
        
        Все значения — строки (str), как в CSV, потому что
        analyse() сам делает float(s['final_exam_score']).
        """
        self.sample = [
            {
                "student_id": "S001",
                "GPA": "3.8",
                "sleep_hours": "7",
                "country": "USA",
                "major": "Computer Science",
                "final_exam_score": "95",
                "study_hours_per_day": "4"
            },
            {
                "student_id": "S002",
                "GPA": "2.5",
                "sleep_hours": "5",
                "country": "India",
                "major": "Mathematics",
                "final_exam_score": "72",
                "study_hours_per_day": "2"
            },
            {
                "student_id": "S003",
                "GPA": "3.9",
                "sleep_hours": "8",
                "country": "USA",
                "major": "Engineering",
                "final_exam_score": "98",
                "study_hours_per_day": "5"
            },
            {
                "student_id": "S004",
                "GPA": "1.8",
                "sleep_hours": "4",
                "country": "Canada",
                "major": "Physics",
                "final_exam_score": "55",
                "study_hours_per_day": "1"
            },
            {
                "student_id": "S005",
                "GPA": "3.5",
                "sleep_hours": "6",
                "country": "India",
                "major": "Biology",
                "final_exam_score": "88",
                "study_hours_per_day": "3"
            },
        ]

    # ──────────────────────────────────────────────────────
    # ТЕСТ 1: После analyse() результат не должен быть пустым
    # ──────────────────────────────────────────────────────
    def test_result_is_not_empty(self):
        """
        Проверяет, что analyse() действительно заполняет self.result.
        
        assertNotEqual(a, b) → тест проходит, если a != b
        Если result остался {}, значит analyse() не работает.
        """
        analyser = TopStudentsAnalyser(self.sample)
        analyser.analyse()
        # {} — пустой словарь; result должен быть не пустым
        self.assertNotEqual(analyser.result, {})

    # ──────────────────────────────────────────────────────
    # ТЕСТ 2: Количество обработанных студентов = 5
    # ──────────────────────────────────────────────────────
    def test_total_students(self):
        """
        Проверяет поле total_students в результате.
        
        assertEqual(a, b) → тест проходит, если a == b
        У нас 5 строк в sample, все корректные → total_students должен быть 5.
        """
        analyser = TopStudentsAnalyser(self.sample)
        analyser.analyse()
        self.assertEqual(analyser.result["total_students"], 5)

    # ──────────────────────────────────────────────────────
    # ТЕСТ 3: Словарь result содержит обязательные ключи (Вариант D)
    # ──────────────────────────────────────────────────────
    def test_result_has_required_keys(self):
        """
        Для Варианта D обязательный ключ в result: "top_10".
        
        assertIn(key, container) → тест проходит, если key в container
        
        Также проверяем другие ожидаемые ключи нашей реализации.
        """
        analyser = TopStudentsAnalyser(self.sample)
        analyser.analyse()
        # Обязательный ключ по заданию (Вариант D)
        self.assertIn("top_10", analyser.result)
        # Дополнительные ключи нашей реализации
        self.assertIn("total_students", analyser.result)
        self.assertIn("variant", analyser.result)
        self.assertIn("analysis_type", analyser.result)

    # ──────────────────────────────────────────────────────
    # ТЕСТ 4: Двойной вызов analyse() даёт одинаковый результат
    # ──────────────────────────────────────────────────────
    def test_analyse_twice(self):
        """
        Проверяет идемпотентность метода analyse().
        Идемпотентность: повторный вызов с теми же данными = тот же результат.
        
        .copy() создаёт поверхностную копию словаря —
        без неё result1 и analyser.result были бы одним объектом,
        и тест всегда проходил бы (сравнивали бы объект с самим собой).
        
        assertEqual(a, b) → тест проходит, если a == b
        """
        analyser = TopStudentsAnalyser(self.sample)
        analyser.analyse()
        # Сохраняем копию результата ПОСЛЕ первого analyse()
        result1 = analyser.result.copy()
        # Второй вызов
        analyser.analyse()
        # Результат должен совпасть
        self.assertEqual(analyser.result, result1)


# Точка входа для запуска тестов напрямую: python tests/test_analyser.py
if __name__ == '__main__':
    unittest.main()
